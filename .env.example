# AI-TA backend — environment template (see config/settings.py for the full
# set of supported variables; this file documents commonly tuned ones).
# Copy to .env and fill in. NEVER commit .env.

# --- Core (required) ---
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_API_KEY=
SUPABASE_DB_URL=

# --- Models ---
# Main solver model (Responses API streaming + blocking solve)
#MAIN_MODEL=gpt-5
# Default-off Apollo one-call coverage + confused-student questioning path.
#APOLLO_UNIFIED_QUESTIONING_ENABLED=false
#APOLLO_UNIFIED_QUESTION_MODEL=gpt-5.2
# Reasoning effort for GPT-5.x Apollo questioning (none|low|medium|high|xhigh)
#APOLLO_UNIFIED_QUESTION_REASONING_EFFORT=low
# Default-off staging diagnostic; logs rejected drafts that may contain private rubric content.
#APOLLO_UNIFIED_QUESTION_DEBUG_LOG=false
# Solver reasoning effort for reasoning models (minimal|low|medium|high)
#MAIN_REASONING_EFFORT=medium
# Parser model for question parsing / scope filtering
#PARSER_MODEL=gpt-4o

# --- Latency tuning (RetrievalV2) ---
# Parallel snippet-scoring pool width (default 24 = one wave for K_SEM=20)
#CITATION_WORKERS=24
# Model for keyword extraction. Default gpt-4o — measured A/B showed
# gpt-4o-mini is ~2x SLOWER for this call (more terms, lower tokens/s).
#KEYWORD_MODEL=gpt-4o
# Model for per-snippet citation scoring. Default gpt-4o (measured: mini is
# ~30% slower per call with identical scores). NOTE: PARSER_MODEL no longer
# affects scoring — this is the single override knob.
#CITATION_SCORER_MODEL=gpt-4o
# Stable prompt-cache routing key for the solver (default aita-solver:<model>)
#PROMPT_CACHE_KEY=
# Opt-in: OpenAI priority processing for faster/more consistent solver tokens
#OPENAI_SERVICE_TIER=priority
# Opt-in: GPT-5 output verbosity (low|medium|high) on the streaming solver
#MAIN_VERBOSITY=low

# --- Retrieval-mode orchestrator (RetrievalV5) ---
# Master switch. Off (default) = pipeline identical to pre-router behavior.
#ROUTER_ENABLED=false
# Mode classifier model (one call per follow-up turn with a warm cache)
#ROUTER_MODEL=gpt-4o-mini
# NONE/AUGMENT decisions below this confidence downgrade to FRESH
#ROUTER_MIN_CONFIDENCE=0.5
# AUGMENT top-up retrieval size + token budget (merged with cached bundle)
#ROUTER_AUGMENT_TOP_K=8
#ROUTER_AUGMENT_TOKEN_BUDGET=2000
# Cap on merged AUGMENT bundle size (default: K_SEM)
#ROUTER_MAX_SNIPPETS=20
# Recent chat turns shown to the mode classifier
#ROUTER_RECENT_TURNS=6
# Per-session LRU cap on cached snippets (chat_session_snippets rows)
#BUNDLE_CACHE_MAX_CHUNKS=40

# --- Cold-cache hybrid-search tuning (HNSW iterative scan) ---
# Engages idx_aita_chunks_embedding_hnsw on the semantic arm so the first
# (cold-cache) query of a session no longer brute-force-detoasts every
# embedding. relaxed_order (default) guarantees the full candidate pool even
# for week-gated classes; strict_order = exact index order; off = exact
# brute-force scan. Recall vs brute force: top-20 overlap 1.000 (see
# scripts/eval_iterative_scan_recall.py).
#HNSW_ITERATIVE_SCAN=relaxed_order
# Initial HNSW candidate count (1..1000). Sized to the top_k*5 candidate LIMIT.
#HNSW_EF_SEARCH=300
# Iterative-scan tuple budget (1000..1000000); raise if recall ever dips.
#HNSW_MAX_SCAN_TUPLES=20000
