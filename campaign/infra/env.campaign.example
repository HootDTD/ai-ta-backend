# Apollo E2E grading campaign — local-stack environment template.
#
# Copy to `.env.campaign` at the repo root and fill in the placeholder values
# from `supabase status -o json` (run after `supabase start`; see
# campaign/README.md for the full bring-up sequence). Every value here points
# ONLY at local Docker containers — never a remote Supabase project or Neo4j
# Aura instance.
#
# Port scheme deviates from the plan's literal sketch (54321/7687 defaults):
# this machine already runs another local Supabase stack + a "maestro-nestjs"
# stack on the 54xxx/55xxx ranges, so the campaign's `supabase/config.toml`
# moves every port into 57320-57329, and the Neo4j compose file uses
# 57687/57474. See campaign/README.md "Port deviations" for the full mapping.

# --- Backend DB (SQLAlchemy async DSN — matches config/settings.py /
#     database/session.py's SUPABASE_DB_URL convention) ---
SUPABASE_DB_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:57322/postgres
# Plain asyncpg DSN some campaign scripts use directly (same DB, no +asyncpg).
CAMPAIGN_DSN=postgresql://postgres:postgres@127.0.0.1:57322/postgres

# --- Supabase local API (from `supabase status -o json` after `supabase start`) ---
SUPABASE_URL=http://127.0.0.1:57321
# The CLI's local "anon" key — safe to hardcode, it is Supabase's published
# local-dev demo JWT, not a real secret (same value CI logs show for the
# ai-ta-backend project's own local stack).
SUPABASE_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# service_role key — needed by campaign/driver/auth.py (D3) to mint student
# JWTs via the GoTrue admin API. Fill from `supabase status -o json` if it
# rotates (project-specific; the anon key above is the fixed local-dev demo
# value, but service_role differs per `supabase init`).
SUPABASE_SERVICE_ROLE_KEY=

# --- Neo4j (campaign/infra/docker-compose.neo4j.yml) ---
NEO4J_URI=bolt://127.0.0.1:57687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=campaignpass
NEO4J_DATABASE=neo4j

# --- OpenAI (only remote dependency — parser/persona/judges are real calls) ---
OPENAI_API_KEY=

# --- Apollo flags for the campaign (paired-shadow mode is the default) ---
APOLLO_GRAPH_SIM_SHADOW_ENABLED=1
APOLLO_GRADING_ARTIFACT_ENABLED=1
APOLLO_CLARIFICATION_ENABLED=1
APOLLO_AUTOPROVISION_ENABLED=1
# Promotion flag — OFF for tuning runs. Flipped on only for the human-run
# staging soak after the gate report passes (spec §5 exit criteria).
APOLLO_GRAPH_GRADER_LIVE=0
