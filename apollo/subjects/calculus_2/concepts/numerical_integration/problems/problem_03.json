      "step": 4,
      "content": {
        "concept": "Simpson coefficient pattern",
        "meaning": "Coefficients run 1, 4, 2, 4, ..., 4, 1: endpoints weight 1, odd-index nodes weight 4, even interior nodes weight 2."
