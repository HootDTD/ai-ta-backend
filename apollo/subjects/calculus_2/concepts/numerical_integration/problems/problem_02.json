      "content": {
        "label": "compute M = 0.5(0.0625 + 0.5625 + 1.5625 + 3.0625) = 0.5(5.25) = 2.625",
        "order": 3,
        "action": "compute M = 0.5(0.0625 + 0.5625 + 1.5625 + 3.0625) = 0.5(5.25) = 2.625",
