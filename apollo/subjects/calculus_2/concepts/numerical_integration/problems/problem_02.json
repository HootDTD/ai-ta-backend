    },
    {
      "id": "plan_evaluate_midpoints",
      "step": 5,
      "content": {
        "label": "evaluate f(x) = x^2 at the midpoints: 0.0625, 0.5625, 1.5625, 3.0625",
        "order": 2,
        "action": "evaluate f(x) = x^2 at the midpoints: 0.0625, 0.5625, 1.5625, 3.0625",
        "purpose": "obtain the midpoint sample values",
        "uses_equations": []
      },
      "depends_on": [
        "plan_compute_step_size",
