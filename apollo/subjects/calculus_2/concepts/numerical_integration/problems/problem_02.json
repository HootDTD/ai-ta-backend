      "content": {
        "concept": "Midpoint sample points",
        "meaning": "The rule samples f at the midpoint of each subinterval: 0.25, 0.75, 1.25, 1.75."
      },
      "depends_on": [],
      "entity_key": "def.midpoint_sample_points",
      "entry_type": "definition"
    },
    {
      "id": "plan_compute_step_size",
      "step": 4,
      "content": {
        "label": "compute Delta x = (2 - 0)/4 = 0.5 and locate the subinterval midpoints",
        "order": 1,
        "action": "compute Delta x = (2 - 0)/4 = 0.5 and locate the subinterval midpoints",
        "purpose": "identify where the integrand is sampled",
