    {
      "id": "midpoint_rule",
      "step": 2,
      "content": {
        "label": "Midpoint Rule: M = Delta x (fm1 + fm2 + fm3 + fm4)",
        "symbolic": "M - h*(fm1 + fm2 + fm3 + fm4)",
        "variables": [
          "M",
          "h",
          "fm1",
          "fm2",
          "fm3",
          "fm4"
        ]
      },
