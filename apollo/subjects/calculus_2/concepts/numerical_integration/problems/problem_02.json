  "reference_solution": [
    {
      "id": "step_size",
      "step": 1,
      "content": {
        "label": "Step size Delta x = (b - a)/n",
        "symbolic": "h - (b - a)/n",
        "variables": [
          "h",
          "b",
          "a",
          "n"
        ]
