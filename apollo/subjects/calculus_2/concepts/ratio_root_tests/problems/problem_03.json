{
  "id": "ratio_two_pow_n_over_n_squared",
  "concept_id": "ratio_root_tests",
  "difficulty": "standard",
  "given_values": {},
  "problem_text": "Use the Ratio Test to determine whether sum_{n=1}^infinity 2^n/n^2 converges or diverges.",
  "layer1_seeded": true,
  "declared_paths": [
    [
      "ratio_test",
      "ratio",
      "plan_form_ratio",
      "plan_take_limit",
      "ratio_greater_than_one",
      "plan_conclude"
    ]
  ],
  "target_unknown": "convergence verdict",
  "symbolic_mappings": {},
  "reference_solution": [
    {
      "id": "ratio_test",
      "step": 1,
      "content": {
        "concept": "Ratio Test",
        "meaning": "L = lim |a_(n+1)/a_n|; if L < 1 the series converges, if L > 1 it diverges, and if L = 1 the test is inconclusive."
      },
      "depends_on": [],
      "entity_key": "def.ratio_test",
      "entry_type": "definition"
    },
    {
      "id": "ratio",
      "step": 2,
      "content": {
        "label": "Ratio a_(n+1)/a_n = 2 n^2/(n+1)^2",
        "symbolic": "r - 2*n**2/(n + 1)**2",
        "variables": [
          "r",
          "n"
        ]
      },
      "depends_on": [],
      "entity_key": "eq.ratio",
      "entry_type": "equation"
    },
    {
      "id": "plan_form_ratio",
      "step": 3,
      "content": {
        "label": "form a_(n+1)/a_n = [2^(n+1)/(n+1)^2] * [n^2/2^n] = 2 n^2/(n+1)^2",
        "order": 1,
        "action": "form a_(n+1)/a_n = [2^(n+1)/(n+1)^2] * [n^2/2^n] = 2 n^2/(n+1)^2",
        "purpose": "build the ratio of consecutive terms",
        "uses_equations": [
          "ratio"
        ]
      },
      "depends_on": [
        "ratio_test"
      ],
      "entity_key": "proc.plan_form_ratio",
      "entry_type": "procedure_step"
    },
    {
      "id": "plan_take_limit",
      "step": 4,
      "content": {
        "label": "compute L = lim 2 (n/(n+1))^2 = 2",
        "order": 2,
        "action": "compute L = lim 2 (n/(n+1))^2 = 2",
        "purpose": "evaluate the ratio limit L",
        "uses_equations": []
      },
      "depends_on": [
        "plan_form_ratio"
      ],
      "entity_key": "proc.plan_take_limit",
      "entry_type": "procedure_step"
    },
    {
      "id": "ratio_greater_than_one",
      "step": 5,
      "content": {
        "label": "Ratio Test: diverges (L>1)",
        "applies_when": "L = 2 > 1."
      },
      "depends_on": [],
      "entity_key": "cond.ratio_greater_than_one",
      "entry_type": "condition"
    },
    {
      "id": "plan_conclude",
      "step": 6,
      "content": {
        "label": "since L > 1, the series diverges by the Ratio Test",
        "order": 3,
        "action": "since L > 1, the series diverges by the Ratio Test",
        "purpose": "reach the divergence verdict",
        "uses_equations": []
      },
      "depends_on": [
        "plan_take_limit",
        "ratio_greater_than_one"
      ],
      "entity_key": "proc.plan_conclude",
      "entry_type": "procedure_step"
    }
  ]
}
