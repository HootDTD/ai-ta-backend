  },
  "problem_text": "Evaluate the definite integral  integral_0^(pi/4) tan(x) sec^2(x) dx.",
  "layer1_seeded": true,
  "declared_paths": [
    [
      "recognize",
      "usub_formula",
      "substitution",
      "power_rule",
      "choose_u",
