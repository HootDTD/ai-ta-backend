{
  "id": "pf_1_over_x2_plus_x",
  "concept_id": "partial_fractions",
  "difficulty": "standard",
  "given_values": {},
  "problem_text": "Evaluate  integral 1/(x^2 + x) dx.",
  "layer1_seeded": true,
  "declared_paths": [
    [
      "factor_denominator",
      "decomposition",
      "log_integral",
      "factor_first",
      "set_up",
      "integrate"
    ]
  ],
  "target_unknown": "F",
  "symbolic_mappings": {},
  "reference_solution": [
    {
      "id": "factor_denominator",
      "step": 1,
      "content": {
        "label": "Factor the denominator first",
        "applies_when": "x^2 + x factors as x(x + 1), so decompose into partial fractions rather than attempt a substitution"
      },
      "depends_on": [],
      "entity_key": "cond.factor_denominator",
      "entry_type": "condition"
    },
    {
      "id": "decomposition",
      "step": 2,
      "content": {
        "label": "Partial-fraction form (distinct linear factors)",
        "symbolic": "1/(x*(x + 1)) = A/x + B/(x + 1)",
        "variables": [
          "A",
          "B",
          "x"
        ]
      },
      "depends_on": [],
      "entity_key": "eq.decomposition",
      "entry_type": "equation"
    },
    {
      "id": "log_integral",
      "step": 3,
      "content": {
        "label": "Integral of a simple pole",
        "symbolic": "integral 1/(x - r) dx = ln|x - r| + C",
        "variables": [
          "x",
          "r"
        ]
      },
      "depends_on": [],
      "entity_key": "eq.log_integral",
      "entry_type": "equation"
    },
    {
      "id": "factor_first",
      "step": 4,
      "content": {
        "label": "Factor the denominator",
        "order": 1,
        "action": "factor x^2 + x = x(x + 1)",
        "purpose": "expose the two distinct linear factors",
        "uses_equations": []
      },
      "depends_on": [
        "factor_denominator"
      ],
      "entity_key": "proc.factor_first",
      "entry_type": "procedure_step"
    },
    {
      "id": "set_up",
      "step": 5,
      "content": {
        "label": "Set up and solve",
        "order": 2,
        "action": "clear denominators: 1 = A(x + 1) + B x; x = 0 gives A = 1, x = -1 gives B = -1",
        "purpose": "determine A and B",
        "uses_equations": [
          "decomposition"
        ]
      },
      "depends_on": [
        "factor_first",
        "decomposition"
      ],
      "entity_key": "proc.set_up",
      "entry_type": "procedure_step"
    },
    {
      "id": "integrate",
      "step": 6,
      "content": {
        "label": "Integrate the simple fractions",
        "order": 3,
        "action": "integrate 1/x - 1/(x + 1): ln|x| - ln|x + 1| + C = ln|x/(x + 1)| + C",
        "purpose": "produce the final antiderivative",
        "uses_equations": [
          "log_integral"
        ]
      },
      "depends_on": [
        "set_up",
        "log_integral"
      ],
      "entity_key": "proc.integrate",
      "entry_type": "procedure_step"
    }
  ]
}
