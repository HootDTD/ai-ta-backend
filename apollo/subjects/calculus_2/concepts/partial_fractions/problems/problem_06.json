{
  "id": "pf_1_over_x_x_minus_1_squared",
  "concept_id": "partial_fractions",
  "difficulty": "hard",
  "given_values": {},
  "problem_text": "Evaluate  integral 1/(x(x - 1)^2) dx.",
  "layer1_seeded": true,
  "declared_paths": [
    [
      "factor_denominator",
      "repeated_factor",
      "decomposition",
      "log_integral",
      "power_integral",
      "set_up",
      "solve_coefficients",
      "integrate"
    ]
  ],
  "target_unknown": "F",
  "symbolic_mappings": {},
  "reference_solution": [
    {
      "id": "factor_denominator",
      "step": 1,
      "content": {
        "label": "Factor the denominator first",
        "applies_when": "the denominator x(x - 1)^2 has a simple linear factor x and a repeated linear factor (x - 1)^2"
      },
      "depends_on": [],
      "entity_key": "cond.factor_denominator",
      "entry_type": "condition"
    },
    {
      "id": "repeated_factor",
      "step": 2,
      "content": {
        "label": "Repeated factor needs one term per power",
        "applies_when": "the repeated linear factor (x - 1)^2 requires two terms in the decomposition: B/(x - 1) + C/(x - 1)^2"
      },
      "depends_on": [],
      "entity_key": "cond.repeated_factor",
      "entry_type": "condition"
    },
    {
      "id": "decomposition",
      "step": 3,
      "content": {
        "label": "Partial-fraction form (simple + repeated linear factor)",
        "symbolic": "1/(x*(x - 1)^2) = A/x + B/(x - 1) + C/(x - 1)^2",
        "variables": [
          "A",
          "B",
          "C",
          "x"
        ]
      },
      "depends_on": [],
      "entity_key": "eq.decomposition",
      "entry_type": "equation"
    },
    {
      "id": "log_integral",
      "step": 4,
      "content": {
        "label": "Integral of a simple pole",
        "symbolic": "integral 1/(x - r) dx = ln|x - r| + C",
        "variables": [
          "x",
          "r"
        ]
      },
      "depends_on": [],
      "entity_key": "eq.log_integral",
      "entry_type": "equation"
    },
    {
      "id": "power_integral",
      "step": 5,
      "content": {
        "label": "Integral of a repeated pole",
        "symbolic": "integral 1/(x - 1)^2 dx = -1/(x - 1) + C",
        "variables": [
          "x"
        ]
      },
      "depends_on": [],
      "entity_key": "eq.power_integral",
      "entry_type": "equation"
    },
    {
      "id": "set_up",
      "step": 6,
      "content": {
        "label": "Set up the decomposition",
        "order": 1,
        "action": "clear denominators: 1 = A(x - 1)^2 + B x(x - 1) + C x",
        "purpose": "reduce the problem to finding A, B, and C including the repeated-factor terms",
        "uses_equations": [
          "decomposition"
        ]
      },
      "depends_on": [
        "factor_denominator",
        "repeated_factor",
        "decomposition"
      ],
      "entity_key": "proc.set_up",
      "entry_type": "procedure_step"
    },
    {
      "id": "solve_coefficients",
      "step": 7,
      "content": {
        "label": "Solve for the coefficients",
        "order": 2,
        "action": "x = 0 gives A = 1, x = 1 gives C = 1; matching x^2: A + B = 0 so B = -1",
        "purpose": "determine A, B, and C",
        "uses_equations": []
      },
      "depends_on": [
        "set_up"
      ],
      "entity_key": "proc.solve_coefficients",
      "entry_type": "procedure_step"
    },
    {
      "id": "integrate",
      "step": 8,
      "content": {
        "label": "Integrate each piece",
        "order": 3,
        "action": "integrate 1/x - 1/(x - 1) + 1/(x - 1)^2: ln|x| - ln|x - 1| - 1/(x - 1) + C = ln|x/(x - 1)| - 1/(x - 1) + C",
        "purpose": "produce the final antiderivative, integrating the repeated factor to a reciprocal",
        "uses_equations": [
          "log_integral",
          "power_integral"
        ]
      },
      "depends_on": [
        "solve_coefficients",
        "log_integral",
        "power_integral"
      ],
      "entity_key": "proc.integrate",
      "entry_type": "procedure_step"
    }
  ]
}
