# Coverage config for the AI-TA backend test suite (Phase 1).
# Run with: pytest --cov --cov-report=term-missing
# Patch-coverage gating (diff-cover vs origin/staging) is wired in Phase 2.

[run]
branch = true
# SQLAlchemy's asyncio bridge runs DB work through greenlet_spawn; without
# greenlet tracing, every line after the first `await db.execute(...)` in a
# coroutine is silently dropped from coverage (verified: raise/branch lines
# executed under TestClient showed as uncovered). "thread" must stay listed —
# naming only "greenlet" REPLACES default thread tracing and blinds coverage
# to TestClient's portal thread entirely.
concurrency = thread, greenlet
# relative_files lets coverage.xml paths match across local + CI checkout roots,
# which diff-cover and the GitHub Actions runner both depend on.
relative_files = true
source = .
omit =
    tests/*
    */tests/*
    .venv/*
    */__pycache__/*
    database/migrations/*
    # campaign/* was blanket-omitted here (Phase 1) to protect the patch gate
    # from campaign/validate_misconception_detector.py and
    # campaign/infra/prewarm_nli.py, two live-LLM-cost scripts that could
    # never run in CI. DB-18 (2026-07-21) found both already deleted by
    # earlier cleanup (only stale __pycache__ remnants remain) and that this
    # omit's `campaign/*` glob matches recursively in coverage.py — silently
    # zeroing out coverage.xml for ALL of campaign/, including
    # campaign/tests/'s own 159 passing tests that pytest.ini's testpaths
    # entry (see its comment) was specifically changed to collect so
    # campaign/** would be MEASURED, not omitted. Removed: campaign/** is now
    # measured like any other source tree.
    # Live-LLM smoke harness: costs money + hits the network, so it can never
    # run in CI — unmeasured under source=. it would starve the diff-cover
    # patch gate (the same failure mode campaign/* used to be blanket-omitted
    # for, above, until campaign/** got its own real test coverage).
    scripts/wave1_live_smoke.py
    # DAG-4 live-LLM evaluation harness: same network/cost exclusion as the
    # wave-1 smoke above; the conductor runs it manually before merge.
    scripts/dag4_granularity_eval.py
    # DAG-5 Docker-backed contraction replay: requires the locally recorded
    # campaign attempt state and never runs in CI.
    scripts/dag5_contraction_replay.py

[report]
show_missing = true
skip_covered = false
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if TYPE_CHECKING:
    if __name__ == .__main__.:
